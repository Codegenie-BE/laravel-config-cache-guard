{
    "name": "codegenie-be/laravel-config-cache-guard",
    "description": "Prevent Laravel from running with stale cached configuration or routes after .env, config or route changes, with a protected repair endpoint for shared hosting without exec().",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/Codegenie-BE/laravel-config-cache-guard",
    "keywords": [
        "laravel",
        "laravel-config",
        "laravel-config-cache",
        "laravel-route-cache",
        "config-cache",
        "route-cache",
        "config-cache-guard",
        "stale-config",
        "stale-routes",
        "stale-cache",
        "deployment",
        "deployment-cache",
        "shared-hosting",
        "ftp-deployment",
        "artisan",
        "env",
        "php",
        "repair-endpoint",
        "exec-disabled",
        "artisan-call",
        "codegenie"
    ],
    "authors": [
        {
            "name": "Codegenie",
            "homepage": "https://www.codegenie.be"
        }
    ],
    "support": {
        "issues": "https://github.com/Codegenie-BE/laravel-config-cache-guard/issues",
        "source": "https://github.com/Codegenie-BE/laravel-config-cache-guard"
    },
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Codegenie\\ConfigCacheGuard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codegenie\\ConfigCacheGuard\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Codegenie\\ConfigCacheGuard\\ConfigCacheGuardServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "format": "pint",
        "format:test": "pint --test"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
